# Copy to .env.local for local dev. Add the same keys in Vercel / Render dashboard.

# --- Supabase (database + auth + cloud workspace sync) ---
# Project Settings → API → Project URL and anon public key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: server-only admin (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Google Gemini (AI Assistant) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Production site URL (optional; Vercel sets VERCEL_URL automatically) ---
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
